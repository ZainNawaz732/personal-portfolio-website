# ===== Copy this file to ".env" and fill in your real values =====

# Port the server runs on
PORT=5000

# Your Gmail address (used to SEND the email)
MAIL_USER=zainn8847@gmail.com

# Gmail App Password (16 chars, NOT your normal Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_PASS=your_16_char_app_password

# Where contact messages should be delivered (defaults to MAIL_USER)
MAIL_TO=zainn8847@gmail.com

# Comma-separated list of allowed front-end origins (CORS)
# For local testing with Live Server / file, you can leave permissive or add your domains
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://zainnawaz732.github.io
